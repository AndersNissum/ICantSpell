{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ICantSpell",
  "version": "0.1.0",
  "identifier": "com.icantspell.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ICantSpell",
        "width": 300,
        "height": 400,
        "visible": false,
        "decorations": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "ICantSpell Overlay",
        "width": 320,
        "height": 220,
        "visible": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "resizable": false
      },
      {
        "label": "onboarding",
        "url": "onboarding.html",
        "title": "Welcome to ICantSpell",
        "width": 600,
        "height": 500,
        "visible": false,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
